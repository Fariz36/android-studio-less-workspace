#!/usr/bin/env bash

set -euo pipefail

SOURCE_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE_PATH" ]]; do
  SOURCE_DIR="$(cd -- "$(dirname -- "$SOURCE_PATH")" && pwd)"
  SOURCE_PATH="$(readlink "$SOURCE_PATH")"
  [[ "$SOURCE_PATH" != /* ]] && SOURCE_PATH="$SOURCE_DIR/$SOURCE_PATH"
done
SCRIPT_DIR="$(cd -- "$(dirname -- "$SOURCE_PATH")" && pwd)"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/lib/android_common.sh"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/lib/android_init.sh"

usage() {
  cat <<'EOF'
Usage:
  ./android [global-options] <command> [command-args]

Global options:
  --project DIR      Android project root
  --module NAME      App module name (default: app)
  --variant NAME     Build variant (default: Debug)
  --serial ID        adb device serial
  --adb-bin PATH     explicit adb/adb.exe path
  --env-file PATH    explicit env file to source
  --app-id ID        Android application id/package
  --activity NAME    Launch activity, e.g. .MainActivity
  -h, --help         Show this help

Commands:
  init DIRECTORY     Create a new Android project skeleton
  setup              Detect project info and write .android-env
  app-info           Print detected project/app metadata
  completion SHELL   Print shell completion script
  doctor             Show detected tools and current config
  devices            Show adb devices
  tasks              Show Gradle tasks
  build              Build the selected variant
  install            Install selected variant on device
  launch             Launch app on device
  logs [filter]      Open logcat, optionally filtered
  clean              Run Gradle clean
  apk-path           Print the detected APK path for the variant

Examples:
  ./android init MyApp --package com.example.myapp
  ./android setup
  ./android app-info
  ./android completion bash
  ./android --project ~/code/MyApp doctor
  ./android --project ~/code/MyApp build
  ./android --project ~/code/MyApp --serial 2a8df356 install
  ./android --project ~/code/MyApp --app-id com.example.app launch
EOF
}

COMMAND_ARGS=()

parse_args() {
  while (($#)); do
    case "$1" in
      --project)
        CLI_PROJECT_DIR="${2:-}"
        shift 2
        ;;
      --module)
        CLI_APP_MODULE="${2:-}"
        shift 2
        ;;
      --variant)
        CLI_BUILD_VARIANT="${2:-}"
        shift 2
        ;;
      --serial)
        CLI_ADB_SERIAL="${2:-}"
        shift 2
        ;;
      --adb-bin)
        CLI_ADB_BIN="${2:-}"
        shift 2
        ;;
      --env-file)
        CLI_ENV_FILE="${2:-}"
        shift 2
        ;;
      --app-id)
        CLI_APP_ID="${2:-}"
        shift 2
        ;;
      --activity)
        CLI_LAUNCH_ACTIVITY="${2:-}"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      --)
        shift
        COMMAND_ARGS=("$@")
        return
        ;;
      *)
        COMMAND="$1"
        shift
        COMMAND_ARGS=("$@")
        return
        ;;
    esac
  done
}

print_config() {
  printf 'project_dir=%s\n' "${PROJECT_DIR:-}"
  printf 'app_module=%s\n' "$APP_MODULE"
  printf 'build_variant=%s\n' "$BUILD_VARIANT"
  printf 'app_id=%s\n' "${APP_ID:-}"
  printf 'launch_activity=%s\n' "${LAUNCH_ACTIVITY:-}"
  printf 'adb_serial=%s\n' "${ADB_SERIAL:-}"
  printf 'adb_bin=%s\n' "${ADB_BIN:-}"
}

cmd_doctor() {
  local sdk_root adb_path gradle_cmd apk_path

  sdk_root="$(detect_android_sdk_root || true)"
  adb_path="$(find_adb || true)"
  gradle_cmd="$(find_gradle_cmd || true)"
  apk_path="$(find_apk_path || true)"

  printf '== Config ==\n'
  print_config
  printf '\n== Tools ==\n'
  printf 'java=%s\n' "$(command -v java || true)"
  printf 'adb=%s\n' "$adb_path"
  printf 'android_sdk_root=%s\n' "$sdk_root"
  printf 'gradle=%s\n' "$gradle_cmd"
  printf 'apktool=%s\n' "$(command -v apktool || true)"
  printf '\n== Project ==\n'
  if [[ -n "${PROJECT_DIR:-}" ]]; then
    printf 'gradle_project=yes\n'
    printf 'apk_path=%s\n' "$apk_path"
  else
    printf 'gradle_project=no\n'
  fi

  if [[ -n "$adb_path" ]]; then
    local device_output
    printf '\n== Devices ==\n'
    if device_output="$(adb_cmd devices 2>&1)"; then
      printf '%s\n' "$device_output"
    else
      warn "adb probe failed"
      printf '%s\n' "$device_output"
    fi
  fi
}

cmd_app_info() {
  ensure_project
  print_detected_app_info
}

cmd_completion() {
  local shell_name="${COMMAND_ARGS[0]:-}"

  case "$shell_name" in
    bash)
      cat <<'EOF'
_androidws_completion() {
  local cur prev words cword
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"

  local commands="init setup app-info completion doctor devices tasks build install launch logs clean apk-path"
  local global_opts="--project --module --variant --serial --adb-bin --env-file --app-id --activity -h --help"
  local path_opts="--project --adb-bin --env-file"
  local shell_opts="bash"

  if [[ $COMP_CWORD -eq 1 ]]; then
    COMPREPLY=( $(compgen -W "$commands $global_opts" -- "$cur") )
    return 0
  fi

  case "$prev" in
    --project|--adb-bin|--env-file)
      COMPREPLY=( $(compgen -f -- "$cur") )
      return 0
      ;;
    --module|--variant|--serial|--app-id|--activity)
      return 0
      ;;
    completion)
      COMPREPLY=( $(compgen -W "$shell_opts" -- "$cur") )
      return 0
      ;;
    init)
      COMPREPLY=( $(compgen -d -- "$cur") )
      return 0
      ;;
  esac

  local command_seen=""
  local i
  for ((i = 1; i < COMP_CWORD; i++)); do
    case "${COMP_WORDS[i]}" in
      init|setup|app-info|completion|doctor|devices|tasks|build|install|launch|logs|clean|apk-path)
        command_seen="${COMP_WORDS[i]}"
        break
        ;;
    esac
  done

  case "$command_seen" in
    "")
      COMPREPLY=( $(compgen -W "$commands $global_opts" -- "$cur") )
      ;;
    completion)
      COMPREPLY=( $(compgen -W "$shell_opts $global_opts" -- "$cur") )
      ;;
    init)
      COMPREPLY=( $(compgen -W "$global_opts --package --app-name --template --min-sdk --compile-sdk --target-sdk --agp --kotlin --gradle --compose-bom --force" -- "$cur") )
      ;;
    logs)
      COMPREPLY=( $(compgen -W "$global_opts" -- "$cur") )
      ;;
    *)
      COMPREPLY=( $(compgen -W "$global_opts" -- "$cur") )
      ;;
  esac
}

complete -F _androidws_completion androidws
EOF
      ;;
    *)
      die "Unsupported completion shell: ${shell_name:-<empty>}. Supported: bash"
      ;;
  esac
}

cmd_setup() {
  local module app_id activity serial env_path

  ensure_project
  module="$(detect_app_module || true)"
  app_id="$(detect_application_id "$module" || true)"
  activity="$(detect_launcher_activity "$module" || true)"
  serial="$(detect_connected_device_serial || true)"
  env_path="$PROJECT_DIR/.android-env"

  cat >"$env_path" <<EOF
# Generated by androidws setup on 2026-04-01
# Review these values if your project uses flavors, suffixes, or multiple apps.

PROJECT_DIR=$PROJECT_DIR
APP_MODULE=${module:-app}
BUILD_VARIANT=${BUILD_VARIANT:-Debug}
ADB_SERIAL=${serial:-}
ADB_BIN=${ADB_BIN:-}
APP_ID=${app_id:-}
LAUNCH_ACTIVITY=${activity:-}
EOF

  printf 'Wrote %s\n\n' "$env_path"
  print_detected_app_info
  printf '\nDouble-check:\n'
  printf '  1. APP_ID matches the package you want to launch/install\n'
  printf '  2. LAUNCH_ACTIVITY is the correct launcher activity\n'
  printf '  3. BUILD_VARIANT matches the APK you usually build\n'
  printf '  4. ADB_SERIAL is correct if you use more than one device\n'
}

cmd_devices() {
  require_adb
  adb_cmd devices
}

cmd_tasks() {
  ensure_project
  run_gradle tasks --all "${COMMAND_ARGS[@]}"
}

cmd_build() {
  ensure_project
  run_gradle ":$APP_MODULE:assemble$BUILD_VARIANT" "${COMMAND_ARGS[@]}"
}

cmd_install() {
  ensure_project
  require_adb

  if ! gradle_install_supported; then
    warn "Gradle installDebug is skipped: this WSL SDK layout only exposes adb.exe, while AGP expects platform-tools/adb."
    local apk_path
    apk_path="$(find_apk_path)"
    [[ -n "$apk_path" ]] || die "Could not locate APK output for variant $BUILD_VARIANT. Run ./android build first."
    adb_cmd install -r "$apk_path"
    return
  fi

  if run_gradle ":$APP_MODULE:install$BUILD_VARIANT" "${COMMAND_ARGS[@]}"; then
    return
  fi

  warn "Gradle install task failed, falling back to adb install -r."
  local apk_path
  apk_path="$(find_apk_path)"
  [[ -n "$apk_path" ]] || die "Could not locate APK output for variant $BUILD_VARIANT."
  adb_cmd install -r "$apk_path"
}

cmd_launch() {
  require_adb
  require_app_id

  if [[ -n "${LAUNCH_ACTIVITY:-}" ]]; then
    adb_cmd shell am start -n "${APP_ID}/${LAUNCH_ACTIVITY}"
    return
  fi

  adb_cmd shell monkey -p "$APP_ID" -c android.intent.category.LAUNCHER 1
}

cmd_logs() {
  require_adb

  if ((${#COMMAND_ARGS[@]} == 0)); then
    adb_cmd logcat
    return
  fi

  adb_cmd logcat "${COMMAND_ARGS[@]}"
}

cmd_clean() {
  ensure_project
  run_gradle clean "${COMMAND_ARGS[@]}"
}

cmd_apk_path() {
  ensure_project
  find_apk_path
}

parse_args "$@"
load_android_env
apply_cli_overrides

if [[ -z "${COMMAND:-}" ]]; then
  usage
  exit 1
fi

case "$COMMAND" in
  init) cmd_init ;;
  setup) cmd_setup ;;
  app-info) cmd_app_info ;;
  completion) cmd_completion ;;
  doctor) cmd_doctor ;;
  devices) cmd_devices ;;
  tasks) cmd_tasks ;;
  build) cmd_build ;;
  install) cmd_install ;;
  launch) cmd_launch ;;
  logs) cmd_logs ;;
  clean) cmd_clean ;;
  apk-path) cmd_apk_path ;;
  -h|--help|help) usage ;;
  *)
    die "Unknown command: $COMMAND"
    ;;
esac
