cmd_editor_setup() {
  local editor_name vscode_dir tasks_file
  editor_name="${COMMAND_ARGS[0]:-}"

  ensure_project

  case "$editor_name" in
    vscode)
      vscode_dir="$PROJECT_DIR/.vscode"
      tasks_file="$vscode_dir/tasks.json"
      if [[ -f "$tasks_file" ]]; then
        die "Refusing to overwrite existing VS Code task file: $tasks_file"
      fi

      mkdir -p "$vscode_dir"
      write_vscode_tasks "$tasks_file"
      printf 'Wrote %s\n' "$tasks_file"
      printf 'Generated tasks:\n'
      printf '  - androidws: app-info\n'
      printf '  - androidws: setup\n'
      printf '  - androidws: doctor\n'
      printf '  - androidws: devices\n'
      printf '  - androidws: wireless doctor\n'
      printf '  - androidws: wireless status\n'
      printf '  - androidws: wireless pair\n'
      printf '  - androidws: wireless connect\n'
      printf '  - androidws: build\n'
      printf '  - androidws: install\n'
      printf '  - androidws: launch\n'
      printf '  - androidws: sync\n'
      printf '  - androidws: run\n'
      printf '  - androidws: wireless run\n'
      printf '  - androidws: logs\n'
      ;;
    "")
      die "editor-setup requires an editor name. Supported: vscode"
      ;;
    *)
      die "Unsupported editor target: $editor_name. Supported: vscode"
      ;;
  esac
}

cmd_setup() {
  local module app_id activity serial env_path generated_date

  ensure_project
  module="$(detect_app_module || true)"
  app_id="$(detect_application_id "$module" || true)"
  activity="$(detect_launcher_activity "$module" || true)"
  serial="$(detect_connected_device_serial || true)"
  env_path="$(project_env_file_path)"
  generated_date="$(date +%F)"

  {
    printf '# Generated by androidws setup on %s\n' "$generated_date"
    printf '# Review these values if your project uses flavors, suffixes, or multiple apps.\n\n'
    env_assignment_line "PROJECT_DIR" "$PROJECT_DIR"
    env_assignment_line "APP_MODULE" "${module:-app}"
    env_assignment_line "BUILD_VARIANT" "${BUILD_VARIANT:-Debug}"
    env_assignment_line "ADB_SERIAL" "${serial:-}"
    env_assignment_line "ADB_BIN" "${ADB_BIN:-}"
    env_assignment_line "APP_ID" "${app_id:-}"
    env_assignment_line "LAUNCH_ACTIVITY" "${activity:-}"
  } >"$env_path"

  printf 'Wrote %s\n\n' "$env_path"
  print_detected_app_info
  printf '\nDouble-check:\n'
  printf '  1. APP_ID matches the package you want to launch/install\n'
  printf '  2. LAUNCH_ACTIVITY is the correct launcher activity\n'
  printf '  3. BUILD_VARIANT matches the APK you usually build\n'
  printf '  4. ADB_SERIAL is correct if you use more than one device\n'
}

cmd_devices() {
  require_adb
  adb_global_cmd devices
}

cmd_tasks() {
  ensure_project
  run_gradle tasks --all "${COMMAND_ARGS[@]}"
}

cmd_build() {
  ensure_project
  run_gradle ":$APP_MODULE:assemble$BUILD_VARIANT" "${COMMAND_ARGS[@]}"
}

cmd_install() {
  ensure_project
  require_adb

  if ! gradle_install_supported; then
    warn "Gradle installDebug is skipped: this WSL SDK layout only exposes adb.exe, while AGP expects platform-tools/adb."
    local apk_path
    apk_path="$(find_apk_path)"
    [[ -n "$apk_path" ]] || die "Could not locate APK output for variant $BUILD_VARIANT. Run ./android build first."
    adb_cmd install -r "$apk_path"
    return
  fi

  if run_gradle ":$APP_MODULE:install$BUILD_VARIANT" "${COMMAND_ARGS[@]}"; then
    return
  fi

  warn "Gradle install task failed, falling back to adb install -r."
  local apk_path
  apk_path="$(find_apk_path)"
  [[ -n "$apk_path" ]] || die "Could not locate APK output for variant $BUILD_VARIANT."
  adb_cmd install -r "$apk_path"
}

cmd_launch() {
  require_adb
  require_app_id

  if [[ -n "${LAUNCH_ACTIVITY:-}" ]]; then
    adb_cmd shell am start -n "${APP_ID}/${LAUNCH_ACTIVITY}"
    return
  fi

  adb_cmd shell monkey -p "$APP_ID" -c android.intent.category.LAUNCHER 1
}

cmd_logs() {
  require_adb

  if ((${#COMMAND_ARGS[@]} == 0)); then
    adb_cmd logcat
    return
  fi

  adb_cmd logcat "${COMMAND_ARGS[@]}"
}

cmd_clean() {
  ensure_project
  run_gradle clean "${COMMAND_ARGS[@]}"
}

cmd_apk_path() {
  ensure_project
  find_apk_path
}

parse_args "$@"
load_android_env
apply_cli_overrides

if [[ -z "${COMMAND:-}" ]]; then
  usage
  exit 1
fi

case "$COMMAND" in
  init) cmd_init ;;
  setup) cmd_setup ;;
  app-info) cmd_app_info ;;
  editor-setup) cmd_editor_setup ;;
  device) cmd_device ;;
  wireless) cmd_wireless ;;
  run) cmd_run ;;
  sync) cmd_sync ;;
  menu) cmd_menu ;;
  completion) cmd_completion ;;
  doctor) cmd_doctor ;;
  devices) cmd_devices ;;
  tasks) cmd_tasks ;;
  build) cmd_build ;;
  install) cmd_install ;;
  launch) cmd_launch ;;
  logs) cmd_logs ;;
  clean) cmd_clean ;;
  apk-path) cmd_apk_path ;;
  -h|--help|help) usage ;;
  *)
    die "Unknown command: $COMMAND"
    ;;
esac
