#!/usr/bin/env bash

set -euo pipefail

SOURCE_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE_PATH" ]]; do
  SOURCE_DIR="$(cd -- "$(dirname -- "$SOURCE_PATH")" && pwd)"
  SOURCE_PATH="$(readlink "$SOURCE_PATH")"
  [[ "$SOURCE_PATH" != /* ]] && SOURCE_PATH="$SOURCE_DIR/$SOURCE_PATH"
done
SCRIPT_DIR="$(cd -- "$(dirname -- "$SOURCE_PATH")" && pwd)"
PROGRAM_NAME="$(basename -- "${0:-android}")"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/lib/android_common.sh"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/lib/android_init.sh"

usage() {
  cat <<EOF
Usage:
  ${PROGRAM_NAME} [global-options] <command> [command-args]

Global options:
  --project DIR      Android project root
  --module NAME      App module name (default: app)
  --variant NAME     Build variant (default: Debug)
  --serial ID        adb device serial
  --adb-bin PATH     explicit adb/adb.exe path
  --env-file PATH    explicit env file to source
  --app-id ID        Android application id/package
  --activity NAME    Launch activity, e.g. .MainActivity
  -h, --help         Show this help

Commands:
  init DIRECTORY     Create a new Android project skeleton
  setup              Detect project info and write .android-env
  app-info           Print detected project/app metadata
  editor-setup NAME  Generate editor integration files
  device ACTION      Manage the selected adb device serial
  wireless ACTION    Pair/connect/manage wireless adb devices
  run                Build, install, and launch
  sync               Build and install only
  menu               Interactive menu for common actions
  completion SHELL   Print shell completion script
  doctor             Show detected tools and current config
  devices            Show adb devices
  tasks              Show Gradle tasks
  build              Build the selected variant
  install            Install selected variant on device
  launch             Launch app on device
  logs [filter]      Open logcat, optionally filtered
  clean              Run Gradle clean
  apk-path           Print the detected APK path for the variant

Examples:
  ${PROGRAM_NAME} init MyApp --package com.example.myapp
  ${PROGRAM_NAME} setup
  ${PROGRAM_NAME} app-info
  ${PROGRAM_NAME} editor-setup vscode
  ${PROGRAM_NAME} device use 2a8df356
  ${PROGRAM_NAME} wireless pair --pair-host 192.168.1.10 --pair-port 37145 --pair-code 123456
  ${PROGRAM_NAME} wireless doctor
  ${PROGRAM_NAME} wireless connect --host 192.168.1.10 --port 41287
  ${PROGRAM_NAME} wireless status
  ${PROGRAM_NAME} run
  ${PROGRAM_NAME} sync
  ${PROGRAM_NAME} menu
  ${PROGRAM_NAME} completion bash
  ${PROGRAM_NAME} --project ~/code/MyApp doctor
  ${PROGRAM_NAME} --project ~/code/MyApp build
  ${PROGRAM_NAME} --project ~/code/MyApp --serial 2a8df356 install
  ${PROGRAM_NAME} --project ~/code/MyApp --app-id com.example.app launch
EOF
}

COMMAND_ARGS=()

parse_args() {
  while (($#)); do
    case "$1" in
      --project)
        CLI_PROJECT_DIR="${2:-}"
        shift 2
        ;;
      --module)
        CLI_APP_MODULE="${2:-}"
        shift 2
        ;;
      --variant)
        CLI_BUILD_VARIANT="${2:-}"
        shift 2
        ;;
      --serial)
        CLI_ADB_SERIAL="${2:-}"
        shift 2
        ;;
      --adb-bin)
        CLI_ADB_BIN="${2:-}"
        shift 2
        ;;
      --env-file)
        CLI_ENV_FILE="${2:-}"
        shift 2
        ;;
      --app-id)
        CLI_APP_ID="${2:-}"
        shift 2
        ;;
      --activity)
        CLI_LAUNCH_ACTIVITY="${2:-}"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      --)
        shift
        COMMAND_ARGS=("$@")
        return
        ;;
      *)
        COMMAND="$1"
        shift
        COMMAND_ARGS=("$@")
        return
        ;;
    esac
  done
}

print_config() {
  printf 'project_dir=%s\n' "${PROJECT_DIR:-}"
  printf 'app_module=%s\n' "$APP_MODULE"
  printf 'build_variant=%s\n' "$BUILD_VARIANT"
  printf 'app_id=%s\n' "${APP_ID:-}"
  printf 'launch_activity=%s\n' "${LAUNCH_ACTIVITY:-}"
  printf 'adb_serial=%s\n' "${ADB_SERIAL:-}"
  printf 'adb_bin=%s\n' "${ADB_BIN:-}"
}

cmd_doctor() {
  local sdk_root adb_path gradle_cmd apk_path

  sdk_root="$(detect_android_sdk_root || true)"
  adb_path="$(find_adb || true)"
  gradle_cmd="$(find_gradle_cmd || true)"
  apk_path="$(find_apk_path || true)"

  printf '== Config ==\n'
  print_config
  printf '\n== Tools ==\n'
  printf 'java=%s\n' "$(command -v java || true)"
  printf 'adb=%s\n' "$adb_path"
  printf 'android_sdk_root=%s\n' "$sdk_root"
  printf 'gradle=%s\n' "$gradle_cmd"
  printf 'apktool=%s\n' "$(command -v apktool || true)"
  printf '\n== Project ==\n'
  if [[ -n "${PROJECT_DIR:-}" ]]; then
    printf 'gradle_project=yes\n'
    printf 'apk_path=%s\n' "$apk_path"
  else
    printf 'gradle_project=no\n'
  fi

  if [[ -n "$adb_path" ]]; then
    local device_output
    printf '\n== Devices ==\n'
    if device_output="$(adb_global_cmd devices 2>&1)"; then
      printf '%s\n' "$device_output"
    else
      warn "adb probe failed"
      printf '%s\n' "$device_output"
    fi
  fi
}

cmd_app_info() {
  ensure_project
  print_detected_app_info
}

cmd_completion() {
  local shell_name="${COMMAND_ARGS[0]:-}"

  case "$shell_name" in
    bash)
      cat <<'EOF'
_androidws_completion() {
  local cur prev words cword
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"

  local commands="init setup app-info editor-setup device wireless run sync menu completion doctor devices tasks build install launch logs clean apk-path"
  local global_opts="--project --module --variant --serial --adb-bin --env-file --app-id --activity -h --help"
  local path_opts="--project --adb-bin --env-file"
  local shell_opts="bash"
  local device_actions="use current"
  local wireless_actions="pair connect status doctor disconnect"
  local wireless_pair_opts="--pair-host --pair-port --pair-code"
  local wireless_connect_opts="--host --port"
  local wireless_disconnect_opts="--serial"

  if [[ $COMP_CWORD -eq 1 ]]; then
    COMPREPLY=( $(compgen -W "$commands $global_opts" -- "$cur") )
    return 0
  fi

  case "$prev" in
    --project|--adb-bin|--env-file)
      COMPREPLY=( $(compgen -f -- "$cur") )
      return 0
      ;;
    --module|--variant|--serial|--app-id|--activity)
      return 0
      ;;
    completion)
      COMPREPLY=( $(compgen -W "$shell_opts" -- "$cur") )
      return 0
      ;;
    init)
      COMPREPLY=( $(compgen -d -- "$cur") )
      return 0
      ;;
    device)
      COMPREPLY=( $(compgen -W "$device_actions $global_opts" -- "$cur") )
      return 0
      ;;
    wireless)
      COMPREPLY=( $(compgen -W "$wireless_actions $global_opts" -- "$cur") )
      return 0
      ;;
    --pair-host|--host|--pair-port|--pair-code|--port)
      return 0
      ;;
  esac

  local command_seen=""
  local i
  for ((i = 1; i < COMP_CWORD; i++)); do
    case "${COMP_WORDS[i]}" in
      init|setup|app-info|editor-setup|device|wireless|run|sync|menu|completion|doctor|devices|tasks|build|install|launch|logs|clean|apk-path)
        command_seen="${COMP_WORDS[i]}"
        break
        ;;
    esac
  done

  case "$command_seen" in
    "")
      COMPREPLY=( $(compgen -W "$commands $global_opts" -- "$cur") )
      ;;
    editor-setup)
      COMPREPLY=( $(compgen -W "vscode $global_opts" -- "$cur") )
      ;;
    device)
      if [[ $COMP_CWORD -eq $((i + 1)) ]]; then
        COMPREPLY=( $(compgen -W "$device_actions $global_opts" -- "$cur") )
        return 0
      fi

      local device_action="${COMP_WORDS[i+1]:-}"
      case "$device_action" in
        use)
          COMPREPLY=( $(compgen -W "$global_opts" -- "$cur") )
          ;;
        current|"")
          COMPREPLY=( $(compgen -W "$global_opts" -- "$cur") )
          ;;
        *)
          COMPREPLY=( $(compgen -W "$global_opts" -- "$cur") )
          ;;
      esac
      ;;
    wireless)
      if [[ $COMP_CWORD -eq $((i + 1)) ]]; then
        COMPREPLY=( $(compgen -W "$wireless_actions $global_opts" -- "$cur") )
        return 0
      fi

      local wireless_action="${COMP_WORDS[i+1]:-}"
      case "$wireless_action" in
        pair)
          COMPREPLY=( $(compgen -W "$wireless_pair_opts $global_opts" -- "$cur") )
          ;;
        connect)
          COMPREPLY=( $(compgen -W "$wireless_connect_opts $global_opts" -- "$cur") )
          ;;
        disconnect)
          COMPREPLY=( $(compgen -W "$wireless_disconnect_opts $global_opts" -- "$cur") )
          ;;
        status|doctor|"")
          COMPREPLY=( $(compgen -W "$global_opts" -- "$cur") )
          ;;
        *)
          COMPREPLY=( $(compgen -W "$global_opts" -- "$cur") )
          ;;
      esac
      ;;
    completion)
      COMPREPLY=( $(compgen -W "$shell_opts $global_opts" -- "$cur") )
      ;;
    init)
      COMPREPLY=( $(compgen -W "$global_opts --package --app-name --template --min-sdk --compile-sdk --target-sdk --agp --kotlin --gradle --compose-bom --force" -- "$cur") )
      ;;
    logs)
      COMPREPLY=( $(compgen -W "$global_opts" -- "$cur") )
      ;;
    *)
      COMPREPLY=( $(compgen -W "$global_opts" -- "$cur") )
      ;;
  esac
}

complete -F _androidws_completion androidws
EOF
      ;;
    *)
      die "Unsupported completion shell: ${shell_name:-<empty>}. Supported: bash"
      ;;
  esac
}

device_usage() {
  cat <<EOF
Usage:
  ${PROGRAM_NAME} [global-options] device use SERIAL
  ${PROGRAM_NAME} [global-options] device current
EOF
}

wireless_usage() {
  cat <<EOF
Usage:
  ${PROGRAM_NAME} [global-options] wireless pair --pair-host HOST --pair-port PORT --pair-code CODE
  ${PROGRAM_NAME} [global-options] wireless connect --host HOST --port PORT
  ${PROGRAM_NAME} [global-options] wireless status
  ${PROGRAM_NAME} [global-options] wireless doctor
  ${PROGRAM_NAME} [global-options] wireless disconnect [--serial HOST:PORT]
EOF
}

wireless_endpoint() {
  local host="$1"
  local port="$2"
  printf '%s:%s\n' "$host" "$port"
}

verify_connected_serial() {
  local serial="$1"
  local attempt

  for attempt in 1 2 3; do
    if list_connected_device_serials | grep -Fx -- "$serial" >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
  done

  return 1
}

persist_selected_serial() {
  local serial="$1"
  local env_path

  env_path="$(project_env_file_path || true)"
  if [[ -n "$env_path" && -f "$env_path" ]]; then
    upsert_env_key "$env_path" "ADB_SERIAL" "$serial"
    printf 'Persisted ADB_SERIAL in %s\n' "$env_path"
    return
  fi

  warn "No project-local .android-env was found to persist ADB_SERIAL."
  printf 'Next step: run %s setup in your project root, then rerun the device selection command if you want it saved.\n' "$PROGRAM_NAME"
}

clear_persisted_serial_if_matching() {
  local serial="$1"
  local env_path stored_serial

  env_path="$(project_env_file_path || true)"
  if [[ -z "$env_path" || ! -f "$env_path" ]]; then
    return 0
  fi

  stored_serial="$(read_env_key_from_file "$env_path" "ADB_SERIAL" || true)"
  if [[ "$stored_serial" == "$serial" ]]; then
    clear_env_key "$env_path" "ADB_SERIAL"
    printf 'Cleared persisted ADB_SERIAL in %s\n' "$env_path"
  fi
}

serial_host() {
  local serial="${1:-}"
  printf '%s\n' "${serial%%:*}"
}

serial_port() {
  local serial="${1:-}"
  printf '%s\n' "${serial##*:}"
}

tcp_endpoint_reachable() {
  local host="$1"
  local port="$2"
  local attempt

  if command -v python3 >/dev/null 2>&1; then
    python3 - "$host" "$port" <<'PY'
import socket
import sys

host = sys.argv[1]
port = int(sys.argv[2])

try:
    with socket.create_connection((host, port), timeout=2):
        pass
except OSError:
    sys.exit(1)
PY
    return
  fi

  for attempt in 1 2 3; do
    if command -v timeout >/dev/null 2>&1; then
      if timeout 2 bash -c 'exec 3<>"/dev/tcp/$1/$2"' _ "$host" "$port" >/dev/null 2>&1; then
        return 0
      fi
    else
      if bash -c 'exec 3<>"/dev/tcp/$1/$2"' _ "$host" "$port" >/dev/null 2>&1; then
        return 0
      fi
    fi

    sleep 1
  done

  return 1
}

print_serial_list() {
  local label="$1"
  local values="$2"

  if [[ -n "$values" ]]; then
    printf '%s=%s\n' "$label" "$values"
  else
    printf '%s=\n' "$label"
  fi
}

cmd_device_use() {
  local serial="${1:-}"

  require_adb
  [[ -n "$serial" ]] || die "device use requires a serial argument."

  ADB_SERIAL="$serial"
  printf 'Active adb serial: %s\n' "$ADB_SERIAL"
  persist_selected_serial "$ADB_SERIAL"
}

cmd_device_current() {
  local configured_serial connected_serials

  require_adb
  configured_serial="${ADB_SERIAL:-}"
  connected_serials="$(list_connected_device_serials | paste -sd, - || true)"

  printf 'configured_adb_serial=%s\n' "$configured_serial"
  print_serial_list "connected_device_serials" "$connected_serials"
}

cmd_device() {
  local action="${COMMAND_ARGS[0]:-}"

  case "$action" in
    use)
      cmd_device_use "${COMMAND_ARGS[1]:-}"
      ;;
    current)
      cmd_device_current
      ;;
    -h|--help|help|"")
      device_usage
      ;;
    *)
      die "Unknown device action: $action"
      ;;
  esac
}

cmd_wireless_pair() {
  local pair_host="" pair_port="" pair_code="" endpoint output

  while (($#)); do
    case "$1" in
      --pair-host)
        pair_host="${2:-}"
        shift 2
        ;;
      --pair-port)
        pair_port="${2:-}"
        shift 2
        ;;
      --pair-code)
        pair_code="${2:-}"
        shift 2
        ;;
      -h|--help)
        wireless_usage
        return 0
        ;;
      *)
        die "Unknown wireless pair option: $1"
        ;;
    esac
  done

  require_adb
  [[ -n "$pair_host" ]] || die "wireless pair requires --pair-host"
  [[ -n "$pair_port" ]] || die "wireless pair requires --pair-port"
  [[ -n "$pair_code" ]] || die "wireless pair requires --pair-code"

  endpoint="$(wireless_endpoint "$pair_host" "$pair_port")"
  if output="$(printf '%s\n' "$pair_code" | adb_global_cmd pair "$endpoint" 2>&1)"; then
    printf '%s\n' "$output"
    return 0
  fi

  printf '%s\n' "$output" >&2
  return 1
}

cmd_wireless_connect() {
  local host="" port="" endpoint output

  while (($#)); do
    case "$1" in
      --host)
        host="${2:-}"
        shift 2
        ;;
      --port)
        port="${2:-}"
        shift 2
        ;;
      -h|--help)
        wireless_usage
        return 0
        ;;
      *)
        die "Unknown wireless connect option: $1"
        ;;
    esac
  done

  require_adb
  [[ -n "$host" ]] || die "wireless connect requires --host"
  [[ -n "$port" ]] || die "wireless connect requires --port"

  endpoint="$(wireless_endpoint "$host" "$port")"
  output="$(adb_global_cmd connect "$endpoint" 2>&1)" || {
    printf '%s\n' "$output" >&2
    return 1
  }
  printf '%s\n' "$output"

  if ! verify_connected_serial "$endpoint"; then
    die "Wireless endpoint $endpoint is not listed as connected in adb devices."
  fi

  ADB_SERIAL="$endpoint"
  printf 'Active wireless serial: %s\n' "$ADB_SERIAL"
  persist_selected_serial "$ADB_SERIAL"
}

cmd_wireless_status() {
  local configured_serial connected_serials

  require_adb
  configured_serial="${ADB_SERIAL:-}"
  connected_serials="$(list_connected_wireless_serials | paste -sd, - || true)"

  printf 'configured_adb_serial=%s\n' "$configured_serial"
  if is_wireless_serial "$configured_serial"; then
    printf 'configured_is_wireless=yes\n'
  else
    printf 'configured_is_wireless=no\n'
  fi
  printf 'connected_wireless_serials=%s\n' "$connected_serials"
}

cmd_wireless_doctor() {
  local configured_serial connected_devices connected_wireless wireless_count
  local host port

  printf '== Wireless Doctor ==\n'

  if ! find_adb >/dev/null 2>&1; then
    printf 'status=missing-adb\n'
    printf 'action=Install Android platform-tools or set ADB_BIN/ANDROID_SDK_ROOT so adb can be found.\n'
    return 0
  fi

  configured_serial="${ADB_SERIAL:-}"
  connected_devices="$(list_connected_device_serials | paste -sd, - || true)"
  connected_wireless="$(list_connected_wireless_serials | paste -sd, - || true)"
  wireless_count="$(list_connected_wireless_serials | sed '/^$/d' | wc -l)"

  printf 'configured_adb_serial=%s\n' "$configured_serial"
  print_serial_list "connected_device_serials" "$connected_devices"
  print_serial_list "connected_wireless_serials" "$connected_wireless"

  if [[ -z "$configured_serial" ]]; then
    if [[ "$wireless_count" -gt 1 ]]; then
      printf 'status=multiple-wireless-devices\n'
      printf 'action=Choose one with %s device use HOST:PORT before running install/launch/logs.\n' "$PROGRAM_NAME"
      return 0
    fi

    if [[ "$wireless_count" -eq 1 ]]; then
      printf 'status=wireless-connected-not-selected\n'
      printf 'action=Select the connected device with %s device use HOST:PORT.\n' "$PROGRAM_NAME"
      return 0
    fi

    printf 'status=no-wireless-selection\n'
    printf 'action=Pair with %s wireless pair ..., then connect with %s wireless connect ...\n' "$PROGRAM_NAME" "$PROGRAM_NAME"
    return 0
  fi

  if ! is_wireless_serial "$configured_serial"; then
    printf 'status=non-wireless-selection\n'
    printf 'action=ADB_SERIAL is currently pinned to a USB/emulator serial. Use %s device use HOST:PORT or %s wireless connect ... to switch.\n' "$PROGRAM_NAME" "$PROGRAM_NAME"
    return 0
  fi

  if list_connected_wireless_serials | grep -Fx -- "$configured_serial" >/dev/null 2>&1; then
    printf 'status=ready\n'
    printf 'action=Wireless device %s is connected and selected.\n' "$configured_serial"
    return 0
  fi

  host="$(serial_host "$configured_serial")"
  port="$(serial_port "$configured_serial")"
  if tcp_endpoint_reachable "$host" "$port"; then
    printf 'status=reachable-not-connected\n'
    printf 'action=The wireless endpoint responds on the network but adb is not connected. Run %s wireless connect --host %s --port %s.\n' "$PROGRAM_NAME" "$host" "$port"
    return 0
  fi

  printf 'status=unreachable-wireless-endpoint\n'
  printf 'action=The configured endpoint %s cannot be reached. Common causes: the phone is not on the same Wi-Fi, Wireless debugging is off, or the debug port changed. Check the phone and reconnect with %s wireless connect.\n' "$configured_serial" "$PROGRAM_NAME"
}

cmd_wireless_disconnect() {
  local serial="" endpoint output

  while (($#)); do
    case "$1" in
      --serial)
        serial="${2:-}"
        shift 2
        ;;
      -h|--help)
        wireless_usage
        return 0
        ;;
      *)
        die "Unknown wireless disconnect option: $1"
        ;;
    esac
  done

  require_adb
  endpoint="${serial:-${ADB_SERIAL:-}}"
  [[ -n "$endpoint" ]] || die "wireless disconnect requires --serial or a configured ADB_SERIAL."
  is_wireless_serial "$endpoint" || die "wireless disconnect expects a HOST:PORT serial, got: $endpoint"

  output="$(adb_global_cmd disconnect "$endpoint" 2>&1)" || {
    printf '%s\n' "$output" >&2
    return 1
  }
  printf '%s\n' "$output"
  clear_persisted_serial_if_matching "$endpoint"
}

cmd_wireless() {
  local action="${COMMAND_ARGS[0]:-}"

  case "$action" in
    pair)
      cmd_wireless_pair "${COMMAND_ARGS[@]:1}"
      ;;
    connect)
      cmd_wireless_connect "${COMMAND_ARGS[@]:1}"
      ;;
    status)
      cmd_wireless_status "${COMMAND_ARGS[@]:1}"
      ;;
    doctor)
      cmd_wireless_doctor "${COMMAND_ARGS[@]:1}"
      ;;
    disconnect)
      cmd_wireless_disconnect "${COMMAND_ARGS[@]:1}"
      ;;
    -h|--help|help|"")
      wireless_usage
      ;;
    *)
      die "Unknown wireless action: $action"
      ;;
  esac
}

cmd_run() {
  cmd_build
  cmd_install
  cmd_launch
}

cmd_sync() {
  cmd_build
  cmd_install
}

cmd_menu() {
  local selection
  cat <<'EOF'
Select an action:
  1) app-info
  2) setup
  3) doctor
  4) devices
  5) build
  6) install
  7) launch
  8) logs
  9) run
  10) sync
  q) quit
EOF
  printf '> '
  read -r selection
  case "$selection" in
    1) cmd_app_info ;;
    2) cmd_setup ;;
    3) cmd_doctor ;;
    4) cmd_devices ;;
    5) cmd_build ;;
    6) cmd_install ;;
    7) cmd_launch ;;
    8) cmd_logs ;;
    9) cmd_run ;;
    10) cmd_sync ;;
    q|Q) return 0 ;;
    *) die "Unknown selection: $selection" ;;
  esac
}

